# ---------------------------------------------------------------------------
# Copy to .env.local and fill in values. Never commit .env.local.
# ---------------------------------------------------------------------------

# Auth.js (required in production)
# Generate: bunx auth secret
AUTH_SECRET=

# Auth.js base URL (required in production so callbacks work)
# Local: omit or use http://localhost:3000
# Vercel: https://your-domain.vercel.app (e.g. https://eoslt.vercel.app)
# AUTH_URL=https://eoslt.vercel.app

# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
# Redirect URIs: add BOTH:
#   http://localhost:3000/api/auth/callback/google
#   https://eoslt.vercel.app/api/auth/callback/google (or your production URL)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Convex (set by `bunx convex dev` for dev; use prod URL in production)
# NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# PoolHub SQL Server (read-only). Example:
# Server=host;Database=dbname;User ID=user;Password=pass;MultipleActiveResultSets=true
POOLHUB_DATABASE_URL=
